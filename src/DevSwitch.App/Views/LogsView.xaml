<?xml version="1.0" encoding="utf-8"?>
<!--
  文件用途：日志查看视图（只读展示 dataRoot\logs 下的日志）。
    - 顶部标题区 + 工具栏（通道过滤 / 刷新 / 打开目录 / 清理过期）。
    - 主体 ListView 逐行展示「时间 / 通道 / 消息」，含表头、空状态与加载圈。
    - 自包含 UserControl：主窗口 new LogsView() 后调用 Initialize(dataRoot)。
  创建日期：2026-06-11
  语言版本要求：WinUI 3 / .NET 8 / C# 12
  NOTE: 合法授权学习使用，仅限本地环境。展示前每行已由 LogReaderService 调用 LogSanitizer 脱敏。
-->
<UserControl
    x:Class="DevSwitch.App.Views.LogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource DevSwitchCardBrush}">
        <Grid.RowDefinitions>
            <!-- 0: 标题区 -->
            <RowDefinition Height="Auto" />
            <!-- 1: 工具栏 -->
            <RowDefinition Height="Auto" />
            <!-- 2: 表头 -->
            <RowDefinition Height="Auto" />
            <!-- 3: 日志列表（占满剩余空间） -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============ 标题区 ============ -->
        <StackPanel Grid.Row="0" Padding="36,26,36,12" Spacing="4">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="{StaticResource DevSwitchPrimaryTextBrush}"
                Text="日志" />
            <TextBlock
                Foreground="{StaticResource DevSwitchMutedTextBrush}"
                Text="查看导入、切换与诊断记录" />
        </StackPanel>

        <!-- ============ 工具栏：左侧通道过滤，右侧操作按钮 ============ -->
        <Grid Grid.Row="1" Margin="36,0,36,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 通道过滤下拉：第一项「全部」由代码隐藏在 Initialize 中补充 -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock
                    Foreground="{StaticResource DevSwitchMutedTextBrush}"
                    Text="通道"
                    VerticalAlignment="Center" />
                <ComboBox
                    x:Name="ChannelComboBox"
                    MinWidth="160"
                    SelectionChanged="OnChannelSelectionChanged" />
                <ProgressRing
                    x:Name="LoadingRing"
                    Width="18"
                    Height="18"
                    IsActive="False"
                    Visibility="Collapsed" />
            </StackPanel>

            <!-- 操作按钮组 -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <Button x:Name="RefreshLogsButton" Click="OnRefreshLogsClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenLogsFolderButton" Click="OnOpenLogsFolderClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE838;" />
                        <TextBlock Text="打开日志目录" />
                    </StackPanel>
                </Button>
                <Button x:Name="PruneLogsButton" Click="OnPruneLogsClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE74D;" />
                        <TextBlock Text="清理过期" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ============ 表头：时间 / 通道 / 消息 ============ -->
        <Border
            Grid.Row="2"
            Margin="36,0,36,8"
            Padding="18,10"
            Background="{StaticResource DevSwitchTableHeaderBrush}"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DevSwitchMutedTextBrush}" Text="时间" />
                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DevSwitchMutedTextBrush}" Text="通道" />
                <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DevSwitchMutedTextBrush}" Text="消息" />
            </Grid>
        </Border>

        <!-- ============ 日志列表 + 空状态 ============ -->
        <Grid Grid.Row="3">
            <ListView
                x:Name="LogListView"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="36,0,36,6"
                            Padding="18,10"
                            Background="{StaticResource DevSwitchSurfaceBrush}"
                            BorderBrush="{StaticResource DevSwitchBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 时间戳：等宽小字、灰色，便于纵向对齐扫读 -->
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="{StaticResource DevSwitchMutedTextBrush}"
                                    Text="{Binding TimestampText}"
                                    VerticalAlignment="Top" />

                                <!-- 通道小标签 -->
                                <Border
                                    Grid.Column="1"
                                    Padding="8,2"
                                    Background="{StaticResource DevSwitchSubtleBrush}"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource DevSwitchAccentTextBrush}"
                                        Text="{Binding Channel}" />
                                </Border>

                                <!-- 消息正文：可换行 -->
                                <TextBlock
                                    Grid.Column="2"
                                    Foreground="{StaticResource DevSwitchPrimaryTextBrush}"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 空状态：无日志时居中提示 -->
            <StackPanel
                x:Name="EmptyStatePanel"
                HorizontalAlignment="Center"
                Spacing="8"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="32"
                    Foreground="{StaticResource DevSwitchMutedTextBrush}"
                    Glyph="&#xE9F9;"
                    HorizontalAlignment="Center" />
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource DevSwitchPrimaryTextBrush}"
                    HorizontalAlignment="Center"
                    Text="暂无日志记录" />
                <TextBlock
                    Foreground="{StaticResource DevSwitchMutedTextBrush}"
                    HorizontalAlignment="Center"
                    MaxWidth="360"
                    Text="操作 DevSwitch 后会在此显示导入、切换与诊断记录。"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
