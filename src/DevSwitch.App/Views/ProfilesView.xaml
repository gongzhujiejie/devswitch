<?xml version="1.0" encoding="utf-8"?>
<!-- 文件用途：DevSwitch「配置档案」页面视图，展示并管理用户保存的 SDK 组合，可一键应用切换。
     创建/修改日期：2026-06-09
     语言版本要求：WinUI 3 / .NET 8
     说明：本控件为自包含 UserControl，由主窗口 new ProfilesView() 并调用 Initialize(dataRoot) 注入数据根。 -->
<UserControl
    x:Class="DevSwitch.App.Views.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- 整体背景使用应用表面色，保证与主窗口风格一致 -->
    <Grid Background="{StaticResource DevSwitchSurfaceBrush}">
        <Grid.RowDefinitions>
            <!-- 第 0 行：标题区，固定高度自适应内容 -->
            <RowDefinition Height="Auto" />
            <!-- 第 1 行：主体内容区（列表 / 空状态），占满剩余空间 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 标题区：大标题 + 副标题 + 右上角新建按钮 ===== -->
        <Grid Grid.Row="0" Padding="28,24,28,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock
                    Text="配置档案"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource DevSwitchPrimaryTextBrush}" />
                <TextBlock
                    Text="保存不同项目的 SDK 组合，一键应用切换"
                    FontSize="13"
                    Foreground="{StaticResource DevSwitchMutedTextBrush}" />
            </StackPanel>

            <!-- 新建档案按钮：使用强调色文本，靠右对齐 -->
            <Button
                x:Name="CreateProfileButton"
                Grid.Column="1"
                VerticalAlignment="Center"
                Padding="16,8"
                Click="CreateProfileButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="新建档案" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ===== 主体内容区 ===== -->
        <Grid Grid.Row="1">
            <!-- 档案卡片列表：用 ScrollViewer 包裹确保可滚动 -->
            <ScrollViewer
                x:Name="ProfilesScrollViewer"
                Padding="28,4,28,28"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollMode="Disabled">
                <ItemsControl x:Name="ProfilesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 单张档案卡片：圆角、卡片底色、细边框、内边距 16 -->
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                CornerRadius="10"
                                Background="{StaticResource DevSwitchCardBrush}"
                                BorderBrush="{StaticResource DevSwitchBorderBrush}"
                                BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：档案名 + SDK 条目摘要 -->
                                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource DevSwitchPrimaryTextBrush}" />
                                        <TextBlock
                                            Text="{Binding Summary}"
                                            FontSize="12"
                                            TextWrapping="Wrap"
                                            Foreground="{StaticResource DevSwitchMutedTextBrush}" />
                                    </StackPanel>

                                    <!-- 右侧：应用 / 重命名 / 删除 三个操作按钮 -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                        <!-- Tag 携带 ProfileId，事件处理时据此定位档案 -->
                                        <Button
                                            Content="应用"
                                            Padding="14,6"
                                            Tag="{Binding Id}"
                                            Click="ApplyProfileButton_Click" />
                                        <Button
                                            Content="重命名"
                                            Padding="14,6"
                                            Tag="{Binding Id}"
                                            Click="RenameProfileButton_Click" />
                                        <Button
                                            Content="删除"
                                            Padding="14,6"
                                            Foreground="{StaticResource DevSwitchAccentTextBrush}"
                                            Tag="{Binding Id}"
                                            Click="DeleteProfileButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ===== 空状态：无档案时居中显示 ===== -->
            <StackPanel
                x:Name="EmptyStatePanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="10"
                Visibility="Collapsed">
                <FontIcon
                    Glyph="&#xE7B8;"
                    FontSize="36"
                    Foreground="{StaticResource DevSwitchMutedTextBrush}" />
                <TextBlock
                    Text="还没有配置档案"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource DevSwitchPrimaryTextBrush}" />
                <TextBlock
                    Text="点击右上角「新建档案」，把常用的 SDK 组合保存起来，下次一键切换"
                    FontSize="13"
                    MaxWidth="360"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource DevSwitchMutedTextBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
